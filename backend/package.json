{
  "name": "aero-sea-sentinel-backend",
  "version": "1.0.0",
  "description": "Aero-Sea Sentinel Platform — Node.js/Express Backend",
  "main": "src/index.js",
  "scripts": {
    "start":              "node src/index.js",
    "dev":                "nodemon src/index.js",
    "migrate":            "node src/db/migrate.js",
    "seed":               "node src/db/seed.js",
    "migrate:seed":       "node src/db/migrate.js && node src/db/seed.js",
    "test":               "jest --coverage",
    "test:watch":         "jest --watch",
    "test:ci":            "jest --coverage --forceExit --detectOpenHandles",
    "test:integration":   "RUN_INTEGRATION=true jest src/tests/integration.test.js --forceExit",
    "hash-pw":            "node src/db/hashPassword.js"
  },
  "dependencies": {
    "express":             "^4.19.2",
    "express-rate-limit":  "^7.3.1",
    "express-validator":   "^7.1.0",
    "cors":                "^2.8.5",
    "helmet":              "^7.1.0",
    "compression":         "^1.7.4",
    "pg":                  "^8.12.0",
    "redis":               "^4.6.14",
    "bcryptjs":            "^2.4.3",
    "jsonwebtoken":        "^9.0.2",
    "ws":                  "^8.18.0",
    "uuid":                "^10.0.0",
    "dotenv":              "^16.4.5",
    "morgan":              "^1.10.0",
    "winston":             "^3.13.0",
    "node-cron":           "^3.0.3",
    "axios":               "^1.7.2",
    "dayjs":               "^1.11.11"
  },
  "devDependencies": {
    "nodemon":   "^3.1.4",
    "jest":      "^29.7.0",
    "supertest": "^7.0.0"
  }
}
