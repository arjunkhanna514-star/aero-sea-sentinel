# ============================================================
# AERO-SEA SENTINEL — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database (PostgreSQL + TimescaleDB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aero_sea_sentinel
DB_USER=sentinel_user
DB_PASSWORD=your_secure_password_here
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_SSL=false

# Redis (WebSocket pub/sub + caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL_SECONDS=60

# JWT
JWT_SECRET=change_me_to_a_very_long_random_secret_256_bits
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# WebSocket
WS_PORT=4001
WS_HEARTBEAT_MS=30000
TELEMETRY_BROADCAST_MS=1000

# Local AI Service (Ollama / Python)
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_MS=30000
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# Logging
LOG_LEVEL=info
LOG_FILE=logs/sentinel.log

# CORS
CORS_ORIGINS=http://localhost:3000,https://aero-sea-sentinel.vercel.app
