# frontend/.env.example
# Copy to .env.local for local development

# API endpoint (use relative path when behind nginx proxy)
VITE_API_URL=http://localhost:4000/api/v1

# WebSocket endpoint
VITE_WS_URL=ws://localhost:4000/ws/telemetry

# Set to "true" to enable demo/offline mode (uses mock data, no backend needed)
VITE_DEMO_MODE=false
