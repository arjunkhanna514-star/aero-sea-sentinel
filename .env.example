# ============================================================
# AERO-SEA SENTINEL — Root Environment
# Copy to .env and fill in production values
# ============================================================

# Database
DB_PASSWORD=sentinel_secret_2025

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# Grafana
GRAFANA_PASSWORD=sentinel_grafana

# Ollama model (llama3:8b, llama3, deepseek-r1:7b, mistral:7b)
OLLAMA_MODEL=llama3:8b

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:3000

# Frontend API URLs (relative for nginx proxy, absolute for direct)
VITE_API_URL=/api/v1
VITE_WS_URL=ws://localhost/ws/telemetry
